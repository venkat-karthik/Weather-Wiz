# Weather Wiz - Environment Configuration
# Copy this file to .env and update with your production values

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
FLASK_ENV=development
SECRET_KEY=your-super-secret-key-change-this-in-production
BASE_URL=http://localhost:5000

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Development (SQLite)
DATABASE_URL=sqlite:///weather_wiz.db

# Production (PostgreSQL - recommended)
# DATABASE_URL=postgresql://username:password@localhost/weather_wiz

# Docker (PostgreSQL)
# DATABASE_URL=postgresql://weather_user:weather_pass@db:5432/weather_wiz

# =============================================================================
# REDIS CONFIGURATION (for caching and sessions)
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@weatherwiz.com

# =============================================================================
# API KEYS
# =============================================================================
# OpenWeatherMap API Key (required)
OPENWEATHER_API_KEY=e9de1b9d4a8110430373f42634038c2d

# Amazon Affiliate Tag (required for affiliate features)
AMAZON_AFFILIATE_TAG=your-affiliate-tag-20

# =============================================================================
# MONITORING AND ANALYTICS
# =============================================================================
# Sentry DSN for error tracking (optional but recommended)
SENTRY_DSN=your-sentry-dsn-here

# Google Analytics ID (optional)
GOOGLE_ANALYTICS_ID=your-ga-id-here

# =============================================================================
# SECURITY SETTINGS
# =============================================================================
ENABLE_REGISTRATION=true
ENABLE_EMAIL_VERIFICATION=false
ENABLE_ANALYTICS=true
ENABLE_AFFILIATE_TRACKING=true

# =============================================================================
# FILE UPLOAD CONFIGURATION
# =============================================================================
MAX_CONTENT_LENGTH=16777216
UPLOAD_FOLDER=uploads

# =============================================================================
# PRODUCTION SETTINGS (uncomment for production)
# =============================================================================
# FLASK_ENV=production
# SESSION_COOKIE_SECURE=true
# SESSION_COOKIE_HTTPONLY=true
# SESSION_COOKIE_SAMESITE=Strict
# FORCE_HTTPS=true

# =============================================================================
# DEVELOPMENT SETTINGS (comment out for production)
# =============================================================================
FLASK_DEBUG=true
MAIL_SUPPRESS_SEND=false
MAIL_DEBUG=true
